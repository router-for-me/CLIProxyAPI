# CLIProxyAPI 部署环境变量
# 复制为 .env 并按需修改

# 镜像地址（默认 GHCR）
# CLI_PROXY_IMAGE=ghcr.io/chaos-agent/cli-proxy-api:latest

# 绑定地址（默认仅本机，由 nginx 反代对外）
BIND_HOST=127.0.0.1

# 时区
TZ=Asia/Shanghai

# 部署模式（留空或 cloud）
# DEPLOY=cloud

# 路径覆盖（通常不需要修改）
# CLI_PROXY_CONFIG_PATH=./data/config.yaml
# CLI_PROXY_AUTH_PATH=./auths
# CLI_PROXY_LOG_PATH=./logs

# Management API 密码（通过环境变量注入）
# MANAGEMENT_PASSWORD=your-management-password
